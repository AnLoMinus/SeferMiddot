rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields: uid, email, displayName, photoURL, role, lastActive
    //
    // Collection: chats
    // Document ID: chatId
    // Fields: userId, title, messages, createdAt
    //
    // Collection: expanded_teachings
    // Document ID: teachingId
    // Fields: chapterTitle, content, author, createdAt
    //
    // Collection: discussions
    // Document ID: discussionId
    // Fields: roomId, userId, userName, message, timestamp
    //
    // Collection: logs
    // Document ID: logId
    // Fields: userId, userEmail, action, details, timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "quadcosmos@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    function isValidChat(data) {
      return data.keys().hasAll(['userId', 'messages']) &&
             data.userId is string &&
             data.messages is list;
    }

    function isValidExpandedTeaching(data) {
      return data.keys().hasAll(['chapterTitle', 'content', 'author']) &&
             data.chapterTitle is string &&
             data.content is string &&
             data.author is string;
    }

    function isValidDiscussion(data) {
      return data.keys().hasAll(['roomId', 'userId', 'message']) &&
             data.roomId is string &&
             data.userId is string &&
             data.message is string;
    }

    function isValidLog(data) {
      return data.keys().hasAll(['userId', 'action', 'timestamp']) &&
             data.userId is string &&
             data.action is string &&
             data.timestamp is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && isValidChat(request.resource.data) && 
                    (request.auth.uid == request.resource.data.userId || isAdmin());
      allow update: if isAuthenticated() && isValidChat(request.resource.data) && 
                    (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    match /expanded_teachings/{teachingId} {
      allow read: if true; // Publicly readable
      allow create, update, delete: if isAdmin() && isValidExpandedTeaching(request.resource.data);
    }

    match /discussions/{discussionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidDiscussion(request.resource.data);
      allow update, delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
    }

    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && isValidLog(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
